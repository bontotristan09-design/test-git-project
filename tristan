#include <iostream>
using namespace std;

int main() {
    int a1, d, n;
    int sum = 0;

    cout << "WELCOME TO NANIWA HARUKAS!" << endl;

    cout << "Enter the first term (a1): ";
    cin >> a1;

    cout << "Enter the common difference (d): ";
    cin >> d;

    cout << "Enter the number of terms (n): ";
    cin >> n;

    cout << endl;

    cout << "Arithmetic Sequence: ";
    for (int i = 0; i < n; i++) {
        int term = a1 + (i * d);
        cout << term << " ";
        sum += term;
    }

    cout << endl;
    cout << "Sum of sequence = " << sum << endl;

    if (sum == 60) {
        cout << "Welcome to the Observation Deck." << endl;
        cout << "\"It's a beautiful sunset, isn't it?\"" << endl;
    }
    else if (sum % 5 == 0 && sum % 3 == 0) {
        cout << "Welcome to the Souvenir Shop." << endl;
    }
    else if (sum % 3 == 0) {
        cout << "Welcome to the Restaurant and Sky Garden." << endl;
    }
    else {
        cout << "Sum of the sequence: " << sum << endl;
    }

    return 0;
}